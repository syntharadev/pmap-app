# 1. Sacar todos los archivos SQL del rastreo de Git (se quedan en tu disco local)
git rm --cached *.sql

# 2. Sellar el paquete de limpieza
git commit -m "chore: Eliminar scripts SQL de la raíz del repositorio"

# 3. Subir el cambio para que desaparezcan de GitHub
git push origin main
